# GitHub Integration - Get at https://github.com/settings/tokens
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=your_github_token_here

# Cricket API - Get free key at https://cricketdata.org/signup.aspx (100 calls/day free)
CRICAPI_KEY=your_cricapi_key_here

# Bzzoiro Sports Data - Get at https://sports.bzzoiro.com (free)
BZZOIRO_KEY=your_bzzoiro_key_here

# Football Data - Get free key at https://www.football-data.org (top 13 leagues)
FOOTBALLDATA_KEY=your_footballdata_key_here

# API Football - Get free key at https://dashboard.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# apifootball.com - Get free key at https://apifootball.com (1019 leagues)
APIFOOTBALL_COM_KEY=your_apifootball_com_key_here

# News API - Get free key at https://newsdata.io
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Sportmonks Cricket - Get free key at https://sportmonks.com/cricket-api
SPORTMONKS_KEY=your_sportmonks_key_here

# YouTube API - Get at https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here
